+export function operationResult(input: string) {
+  const trimmed = input.trim();
+  const actions = ["trimmed_input"];
+  const errors: Array<{ name: string; message: string }> = [];
+  const metrics = { inputLength: input.length, outputLength: trimmed.length };
+
+  return {
+    op: "example.operation_result",
+    ok: true,
+    actions,
+    skips: [],
+    errors,
+    metrics,
+    value: trimmed
+  };
+}
